# ─────────────────────────────────────────────────────────────────────
#  KBOT — Environment Configuration
#  Copy this file to .env and fill in your real values.
#  NEVER commit your .env file to git.
# ─────────────────────────────────────────────────────────────────────

# ── Kalshi API ────────────────────────────────────────────────────────
# Your Key ID from https://kalshi.com/account/profile/api
KALSHI_KEY_ID=your-kalshi-key-id-here

# Path to your RSA private key .pem file (absolute or relative to kbot/)
KALSHI_PRIVATE_KEY_PATH=./private_key.pem

# "demo" = paper trading against Kalshi demo env (safe)
# "live" = real money on live Kalshi (only when ready)
KALSHI_ENV=demo

# ── Paper trading ─────────────────────────────────────────────────────
# Keep PAPER_TRADING=true until you've verified the bot is working
PAPER_TRADING=true
PAPER_STARTING_BALANCE=100.00
PAPER_KILL_SWITCH_BALANCE=70.00

# ── External data APIs ────────────────────────────────────────────────
# FRED: free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key-here

# EIA: free key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key-here

# ── Database ──────────────────────────────────────────────────────────
# Local SQLite (default):
DATABASE_URL=sqlite:///kbot.db
# Railway PostgreSQL (set automatically by Railway when you add a Postgres plugin):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Optional overrides ────────────────────────────────────────────────
# DB_PATH=kbot.db
# DASHBOARD_PORT=5000
